# Basic Profile Brewfile

# --- Command Line Tools (brew) ---
brew "bat"
brew "croc"
brew "curl"
brew "fzf"
brew "gh"
brew "git"
brew "htop"
brew "jq"
brew "mas"
brew "shellcheck"
brew "tldr"
brew "tree"
brew "uv"
brew "wget"
brew "zsh-autosuggestions"
brew "zsh-completions"

# --- Graphical Apps (cask) ---
cask "1password"
cask "appcleaner"
cask "google-chrome"
cask "grandperspective"
cask "mac-mouse-fix"

# --- Mac App Store Apps (mas) ---
